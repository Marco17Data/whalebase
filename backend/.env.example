# 选择使用哪个 LLM provider: gemini | deepseek | claude | openai
LLM_PROVIDER=gemini

# Google Gemini API Key（推荐起步，有免费额度）
# 申请地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# DeepSeek API Key（可选，便宜）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Claude API Key（可选，质量最好）
# 申请地址：https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# OpenAI API Key（可选）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS 允许的前端地址（部署时改成你的前端 URL）
FRONTEND_ORIGIN=http://localhost:5173
